<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="popupOverlay" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="game.controller.PopupRulesController">
   <children>
      <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="300.0" prefWidth="400.0" spacing="10.0" styleClass="popup-box">
         <children>
            <Label text="GAME RULES" />
            <TextArea editable="false" prefHeight="200.0" prefWidth="200.0" text="SJDKDKD&#10;">
               <VBox.margin>
                  <Insets left="20.0" right="20.0" />
               </VBox.margin>
            </TextArea>
            <Button fx:id="btnClose" mnemonicParsing="false" styleClass="close-button" text="CLOSE" />
         </children>
         <padding>
            <Insets bottom="25.0" top="30.0" />
         </padding>
      </VBox>
   </children>
   <stylesheets>
      <URL value="@../css/popup.css" />
      <URL value="@../css/global.css" />
   </stylesheets>
</StackPane>
