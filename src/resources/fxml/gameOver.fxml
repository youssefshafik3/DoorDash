<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="320.0" prefWidth="420.0" spacing="22.0" styleClass="popup-box" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="game.controller.GameOverController">
   <children>
      <Label styleClass="popup-text" text="GAME OVER" />
      
      <Label fx:id="lblWinner" styleClass="popup-text" text="🏆 VICTOR: Unknown" />
      
      <VBox alignment="CENTER" spacing="8.0" style="-fx-background-color: rgba(0,0,0, 0.2); -fx-background-radius: 10px;">
         <children>
            <Label styleClass="popup-text" text="FINAL ENERGY LEVELS" />
            <Label fx:id="lblScarerEnergy" styleClass="popup-text" text="⚡ Scarer Energy: 0 AP" />
            <Label fx:id="lblLaugherEnergy" styleClass="popup-text" text="🔋 Laugher Energy: 0 AP" textFill="#33ff33">
               <font>
                  <Font name="System Bold" size="15.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
         </padding>
      </VBox>
      
      <Button fx:id="btnMenu" mnemonicParsing="false" onAction="#handleReturnToMenu" prefHeight="40.0" prefWidth="220.0" styleClass="close-button" text="RETURN TO MAIN MENU">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>
   </children>
   <padding>
      <Insets bottom="30.0" left="35.0" right="35.0" top="35.0" />
   </padding>
   <stylesheets>
      <URL value="@../css/popup.css" />
      <URL value="@../css/global.css" />
   </stylesheets>
</VBox>
